{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tmu-room-board",
  "main": "worker.js",
  "compatibility_date": "2026-06-04",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tmu-room-board",
      "database_id": "06cabc34-05e6-444b-91f5-e14368b661f3"
    }
  ]
}
